<!DOCTYPE html>

<html lang="ko">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>🏸 배드민턴 퀴즈</title>

<style>

body {

    font-family: 'Arial', sans-serif;

    background: #f5f7ff;

    margin: 0;

    padding: 0;

    text-align: center;

}

.container {

    padding: 20px;

}

.card {

    background: white;

    border-radius: 20px;

    padding: 20px;

    margin-top: 20px;

    box-shadow: 0 4px 10px rgba(0,0,0,0.1);

}

button {

    width: 100%;

    margin: 8px 0;

    padding: 12px;

    border: none;

    border-radius: 12px;

    font-size: 16px;

    background: #e0e7ff;

}

.correct {

    background-color: #a5f3a5 !important;

}

.wrong {

    background-color: #fca5a5 !important;

}

.hidden {

    display: none;

}

.mascot {

    font-size: 40px;

}

</style>

</head>

<body>

<div class="container">

    <div class="mascot">🐰🏸</div>

    <h2>배드민턴 퀴즈</h2>

    

    <div id="quiz" class="card"></div>

    <div id="result" class="card hidden"></div>

</div>

<script>

const quizData = [

{

    question: "배드민턴에서 사용하는 공의 이름은?",

    options: ["볼", "셔틀콕", "공깃돌", "스피드볼"],

    answer: 1,

    explanation: "배드민턴 공은 '셔틀콕'이라고 불러요!"

},

{

    question: "배드민턴 코트의 중앙선 역할은?",

    options: ["서브 위치 구분", "점수 표시", "라인 장식", "경계선 표시"],

    answer: 0,

    explanation: "중앙선은 서브 위치를 나누는 기준이에요."

},

{

    question: "배드민턴 경기에서 한 세트는 몇 점?",

    options: ["11점", "15점", "21점", "30점"],

    answer: 2,

    explanation: "배드민턴은 21점제 경기입니다."

},

{

    question: "셔틀콕이 네트를 넘지 못하면?",

    options: ["점수 없음", "다시 시작", "상대 점수", "무효"],

    answer: 2,

    explanation: "네트를 넘지 못하면 상대에게 점수가 갑니다."

},

{

    question: "배드민턴에서 라켓으로 치는 기술은?",

    options: ["드리블", "스매시", "패스", "슛"],

    answer: 1,

    explanation: "강하게 내려치는 기술은 스매시입니다."

}

];

let current = 0;

let score = 0;

function loadQuestion() {

    const q = quizData[current];

    const quizDiv = document.getElementById("quiz");

    let html = `<h3>${current + 1}. ${q.question}</h3>`;

    q.options.forEach((opt, i) => {

        html += `<button onclick="checkAnswer(${i})">${opt}</button>`;

    });

    html += `<p id="explanation" class="hidden"></p>`;

    quizDiv.innerHTML = html;

}

function checkAnswer(selected) {

    const buttons = document.querySelectorAll("button");

    const correct = quizData[current].answer;

    buttons.forEach((btn, i) => {

        btn.disabled = true;

        if (i === correct) btn.classList.add("correct");

        if (i === selected && i !== correct) btn.classList.add("wrong");

    });

    if (selected === correct) score++;

    const exp = document.getElementById("explanation");

    exp.classList.remove("hidden");

    exp.innerText = quizData[current].explanation;

    setTimeout(() => {

        current++;

        if (current < quizData.length) {

            loadQuestion();

        } else {

            showResult();

        }

    }, 2000);

}

function showResult() {

    document.getElementById("quiz").classList.add("hidden");

    const resultDiv = document.getElementById("result");

    resultDiv.classList.remove("hidden");

    resultDiv.innerHTML = `

        <h2>🎉 결과</h2>

        <p>${score} / ${quizData.length} 점</p>

        <p>${score >= 4 ? "잘했어요! 🏆" : "조금 더 공부해봐요! 💪"}</p>

        <button onclick="location.reload()">다시하기</button>

    `;

}

loadQuestion();

</script>

</body>

</html>
