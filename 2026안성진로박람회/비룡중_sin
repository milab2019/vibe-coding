<!DOCTYPE html>

<html lang="ko">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>🦖 공룡 퀴즈</title>

<style>

body {

    font-family: Arial, sans-serif;

    margin: 0;

    padding: 0;

    background: #f0f9ff;

    display: flex;

    justify-content: center;

}

.container {

    max-width: 400px;

    width: 100%;

    padding: 20px;

}

.card {

    background: white;

    border-radius: 20px;

    padding: 20px;

    box-shadow: 0 4px 10px rgba(0,0,0,0.1);

}

h1 {

    text-align: center;

}

button {

    width: 100%;

    padding: 12px;

    margin: 6px 0;

    border: none;

    border-radius: 10px;

    background: #e0f2fe;

    font-size: 16px;

}

.correct {

    background: #a5f3a5 !important;

}

.wrong {

    background: #fca5a5 !important;

}

#explanation {

    margin-top: 10px;

    font-size: 14px;

}

.hidden {

    display: none;

}

</style>

</head>

<body>



<div class="container">

    <div class="card" id="quizBox">

        <h1>🦖 공룡 퀴즈</h1>

        <p id="question"></p>

        <div id="choices"></div>

        <p id="explanation"></p>

        <button id="nextBtn" class="hidden">다음 ➡️</button>

    </div>



    <div class="card hidden" id="resultBox">

        <h1>🎉 결과</h1>

        <p id="score"></p>

        <p>🦕 고생했어요!</p>

    </div>

</div>



<script>

const quizData = [

    {

        question: "티라노사우루스는 어떤 특징이 있을까요?",

        choices: ["긴 목", "강한 턱", "날개", "수영 능력"],

        answer: 1,

        explanation: "티라노사우루스는 강한 턱과 이빨로 유명해요!"

    },

    {

        question: "초식 공룡은 무엇을 먹나요?",

        choices: ["고기", "물고기", "식물", "곤충"],

        answer: 2,

        explanation: "초식 공룡은 식물을 먹어요."

    },

    {

        question: "목이 긴 공룡은?",

        choices: ["벨로시랩터", "브라키오사우루스", "티라노사우루스", "트리케라톱스"],

        answer: 1,

        explanation: "브라키오사우루스는 긴 목으로 유명해요."

    },

    {

        question: "세 개의 뿔을 가진 공룡은?",

        choices: ["트리케라톱스", "스테고사우루스", "티라노사우루스", "안킬로사우루스"],

        answer: 0,

        explanation: "트리케라톱스는 세 개의 뿔이 있어요."

    },

    {

        question: "공룡은 어느 시대에 살았나요?",

        choices: ["빙하기", "중생대", "현대", "신생대"],

        answer: 1,

        explanation: "공룡은 중생대에 살았어요."

    }

];



let current = 0;

let score = 0;



const questionEl = document.getElementById("question");

const choicesEl = document.getElementById("choices");

const explanationEl = document.getElementById("explanation");

const nextBtn = document.getElementById("nextBtn");



function loadQuestion() {

    explanationEl.textContent = "";

    nextBtn.classList.add("hidden");

    choicesEl.innerHTML = "";



    const q = quizData[current];

    questionEl.textContent = q.question;



    q.choices.forEach((choice, index) => {

        const btn = document.createElement("button");

        btn.textContent = choice;

        btn.onclick = () => selectAnswer(btn, index);

        choicesEl.appendChild(btn);

    });

}



function selectAnswer(button, index) {

    const correct = quizData[current].answer;

    const buttons = choicesEl.querySelectorAll("button");



    buttons.forEach((btn, i) => {

        btn.disabled = true;

        if (i === correct) btn.classList.add("correct");

        if (i === index && i !== correct) btn.classList.add("wrong");

    });



    if (index === correct) score++;



    explanationEl.textContent = quizData[current].explanation;

    nextBtn.classList.remove("hidden");

}



nextBtn.onclick = () => {

    current++;

    if (current < quizData.length) {

        loadQuestion();

    } else {

        showResult();

    }

};



function showResult() {

    document.getElementById("quizBox").classList.add("hidden");

    const resultBox = document.getElementById("resultBox");

    resultBox.classList.remove("hidden");

    document.getElementById("score").textContent = `점수: ${score} / ${quizData.length}`;

}



loadQuestion();

</script>



</body>

</html>



