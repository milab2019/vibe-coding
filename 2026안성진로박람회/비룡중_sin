<!DOCTYPE html>

<html lang="ko">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>⚽ 축구 퀴즈 게임</title>

<style>

body {

    margin: 0;

    font-family: Arial;

    background: linear-gradient(135deg, #43cea2, #185a9d);

    display: flex;

    justify-content: center;

    align-items: center;

    height: 100vh;

}

.app {

    background: white;

    border-radius: 20px;

    padding: 20px;

    width: 90%;

    max-width: 420px;

    text-align: center;

    box-shadow: 0 10px 25px rgba(0,0,0,0.25);

}

h1 {

    margin-top: 0;

}

.question {

    font-size: 18px;

    margin: 20px 0;

}

button {

    display: block;

    width: 90%;

    margin: 10px auto;

    padding: 12px;

    border: none;

    border-radius: 10px;

    background: #ff7b54;

    color: white;

    font-size: 16px;

    cursor: pointer;

}

button:hover {

    background: #ff5722;

}

.result {

    font-size: 20px;

    margin-top: 15px;

}

.score {

    margin-top: 10px;

}

</style>

</head>

<body>

<div class="app">

    <h1>⚽ 축구 퀴즈</h1>

    <div class="question" id="question"></div>

    <button onclick="answer(0)" id="btn0"></button>

    <button onclick="answer(1)" id="btn1"></button>

    <button onclick="answer(2)" id="btn2"></button>

    <button onclick="answer(3)" id="btn3"></button>

    <div class="result" id="result"></div>

    <div class="score" id="score"></div>

</div>

<script>

const quiz = [

    {

        q: "⚽ 축구 한 팀의 인원은 몇 명일까?",

        a: ["9명", "10명", "11명", "12명"],

        correct: 2

    },

    {

        q: "🏆 월드컵은 몇 년마다 열릴까?",

        a: ["2년", "3년", "4년", "5년"],

        correct: 2

    },

    {

        q: "🇰🇷 한국 축구의 별명은?",

        a: ["푸른 호랑이", "붉은 악마", "백호", "코리안 드래곤"],

        correct: 1

    },

    {

        q: "⚽ 경기 시간은 몇 분일까?",

        a: ["60분", "70분", "80분", "90분"],

        correct: 3

    },

    {

        q: "🥅 골키퍼가 손을 쓸 수 있는 곳은?",

        a: ["중앙선", "페널티 박스", "코너", "아무데나"],

        correct: 1

    }

];

let current = 0;

let score = 0;

function loadQuiz() {

    document.getElementById("result").innerText = "";

    let q = quiz[current];

    document.getElementById("question").innerText = q.q;

    for (let i = 0; i < 4; i++) {

        document.getElementById("btn" + i).innerText = q.a[i];

    }

}

function answer(i) {

    if (i === quiz[current].correct) {

        document.getElementById("result").innerText = "🎉 정답!";

        score++;

    } else {

        document.getElementById("result").innerText = "😢 틀림!";

    }

    current++;

    setTimeout(() => {

        if (current < quiz.length) {

            loadQuiz();

        } else {

            document.querySelector(".app").innerHTML =

                `<h1>게임 끝!</h1>

                 <p>점수: ${score} / ${quiz.length}</p>

                 <button onclick="location.reload()">다시하기</button>`;

        }

        document.getElementById("score").innerText =

            점수: ${score};

    }, 1000);

}

loadQuiz();

</script>

</body>

</html>
















































































































































































































































































































































































































































































































