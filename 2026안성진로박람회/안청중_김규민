<!DOCTYPE html>

<html lang="ko">

<head>

<meta charset="UTF-8">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>🎮 게임 퀴즈</title>

<style>

body {

    font-family: 'Arial', sans-serif;

    margin: 0;

    padding: 0;

    background: #f5f7ff;

    text-align: center;

}

.container {

    padding: 20px;

    max-width: 500px;

    margin: auto;

}

h1 {

    font-size: 24px;

}

.mascot {

    font-size: 50px;

}

.question {

    font-size: 18px;

    margin: 20px 0;

}

.option {

    display: block;

    background: white;

    margin: 10px 0;

    padding: 12px;

    border-radius: 10px;

    border: 2px solid #ddd;

    cursor: pointer;

}

.option.correct {

    background: #c8f7c5;

    border-color: green;

}

.option.wrong {

    background: #f7c5c5;

    border-color: red;

}

.explanation {

    margin-top: 15px;

    font-size: 14px;

    color: #555;

}

button {

    margin-top: 20px;

    padding: 10px 20px;

    border: none;

    border-radius: 10px;

    background: #6c8cff;

    color: white;

    font-size: 16px;

}

.hidden {

    display: none;

}

</style>

</head>

<body>



<div class="container">

    <div class="mascot">🐱🎮</div>

    <h1>게임 퀴즈</h1>

    <div id="quiz"></div>

    <button id="nextBtn" class="hidden">다음</button>

</div>



<script>

const quizData = [

    {

        question: "마리오가 처음 등장한 게임은?",

        options: ["슈퍼 마리오 브라더스", "동키콩", "마리오 카트", "젤다의 전설"],

        answer: 1,

        explanation: "마리오는 1981년 '동키콩'에서 처음 등장했습니다."

    },

    {

        question: "포켓몬에서 피카츄의 타입은?",

        options: ["불", "물", "전기", "풀"],

        answer: 2,

        explanation: "피카츄는 전기 타입 포켓몬입니다."

    },

    {

        question: "리그 오브 레전드에서 맵 이름은?",

        options: ["왕의 협곡", "소환사의 협곡", "전장의 협곡", "용의 협곡"],

        answer: 1,

        explanation: "LOL의 기본 맵은 '소환사의 협곡'입니다."

    },

    {

        question: "마인크래프트에서 크리퍼는 무엇을 하나요?",

        options: ["점프", "폭발", "도망", "춤"],

        answer: 1,

        explanation: "크리퍼는 가까이 가면 폭발합니다."

    },

    {

        question: "젤다의 전설 주인공 이름은?",

        options: ["젤다", "링크", "가논", "에포나"],

        answer: 1,

        explanation: "주인공은 링크이고, 젤다는 공주입니다."

    }

];



let current = 0;

let score = 0;



const quiz = document.getElementById("quiz");

const nextBtn = document.getElementById("nextBtn");



function loadQuestion() {

    nextBtn.classList.add("hidden");

    const q = quizData[current];

    quiz.innerHTML = `

        <div class="question">${q.question}</div>

        ${q.options.map((opt, i) => `<div class="option" onclick="selectAnswer(${i})">${opt}</div>`).join("")}

        <div class="explanation hidden"></div>

    `;

}



function selectAnswer(index) {

    const q = quizData[current];

    const options = document.querySelectorAll(".option");

    const explanation = document.querySelector(".explanation");



    options.forEach((opt, i) => {

        opt.onclick = null;

        if (i === q.answer) {

            opt.classList.add("correct");

        } else if (i === index) {

            opt.classList.add("wrong");

        }

    });



    if (index === q.answer) score++;



    explanation.classList.remove("hidden");

    explanation.innerText = "💡 " + q.explanation;



    nextBtn.classList.remove("hidden");

}



nextBtn.onclick = () => {

    current++;

    if (current < quizData.length) {

        loadQuestion();

    } else {

        showResult();

    }

};



function showResult() {

    quiz.innerHTML = `

        <h2>🎉 결과 🎉</h2>

        <p>${quizData.length}문제 중 ${score}개 맞혔어요!</p>

        <div class="mascot">🐱✨</div>

    `;

    nextBtn.style.display = "none";

}



loadQuestion();

</script>



</body>

</html>



